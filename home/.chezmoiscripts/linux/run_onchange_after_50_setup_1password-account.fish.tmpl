{{- if and (.is_desktop) (not .is_wsl) -}}
#!/usr/bin/env fish

# 1Password CLI is installed via Homebrew (see .chezmoidata.yaml brew_packages).
# This script only handles initial account setup.

if not command -v op >/dev/null
    echo "op not on PATH — skipping 1Password account setup"
    exit 0
end

set account_list (op account list 2>/dev/null)

if test -z "$account_list"
    echo "No 1Password accounts found, adding account..."
    op account add --address {{ .opsubdomain }}.1password.com --email {{ .opemail }}
end

{{ end -}}
